---
import { useTranslations } from '../i18n/utils';
import { ui } from '../i18n/ui';
import flower19 from '../assets/flowers/19.png';

interface Props {
  title?: string;
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang as any);

const seoTitle = t('seo.title');
const seoDescription = t('seo.description');
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(flower19.src, Astro.site);
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{seoTitle}</title>
    <meta name="title" content={seoTitle} />
    <meta name="description" content={seoDescription} />
    <meta name="author" content="Jill Hernández" />
    <meta name="keywords" content="Jill Hernández, Jillglypuff, Full-Stack Developer, Vue, React, PHP, Node.js, Web Development, Mobile Apps" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:image" content={ogImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={seoTitle} />
    <meta property="twitter:description" content={seoDescription} />
    <meta property="twitter:image" content={ogImageURL} />

    <!-- Multilingual SEO -->
    <link rel="canonical" href={canonicalURL} />
    {Object.keys(ui).map((l) => (
      <link
        rel="alternate"
        hreflang={l}
        href={new URL(`/${l}${Astro.url.pathname.replace(/^\/[a-z]{2}/, '')}`, Astro.site)}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(`/es`, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=Dancing+Script:wght@400..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
