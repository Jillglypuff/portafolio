---
import { useTranslations } from '../i18n/utils';
import { Icon } from 'astro-icon/components';

const { lang } = Astro.props;
const t = useTranslations(lang);
---
<nav class="nav" id="nav">
  <a href={`/${lang}/#hero`} class="nav-logo">Jill H.</a>
  
  <div class="nav-menu-group">
    <ul class="nav-links">
      <li><a href={`/${lang}/#about`}>{t('nav.about')}</a></li>
      <li><a href={`/${lang}/#skills`}>{t('nav.tech')}</a></li>
      <li><a href={`/${lang}/#experience`}>{t('nav.projects')}</a></li>
      <li><a href={`/${lang}/blog/`}>{t('nav.blog')}</a></li>
    </ul>

    <div class="nav-actions">
      <a href={`/${lang}/#contact`} class="nav-cta">{t('nav.contact')}</a>
      
      <!-- Language Dropdown - Far Right Corner -->
      <div class="lang-selector">
        <button class="lang-btn" id="lang-btn" aria-label="Select language">
          <Icon name="lucide:globe" size={18} />
          <Icon name="lucide:chevron-down" size={12} class="chevron" />
        </button>
        
        <div class="lang-dropdown" id="lang-menu">
          <div class="dropdown-inner">
            <a href="/en/" class={lang === 'en' ? 'active' : ''}>
              <span class="flag">🇺🇸</span> English
            </a>
            <a href="/es/" class={lang === 'es' ? 'active' : ''}>
              <span class="flag">🇪🇸</span> Español
            </a>
            <a href="/pt/" class={lang === 'pt' ? 'active' : ''}>
              <span class="flag">🇧🇷</span> Português
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('lang-btn');
  const menu = document.getElementById('lang-menu');

  if (btn && menu) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('is-open');
      btn.classList.toggle('is-active');
    });

    document.addEventListener('click', () => {
      menu.classList.remove('is-open');
      btn.classList.remove('is-active');
    });
  }
</script>

<style>
  /* Use global.css structure, only adding the necessary grouping and dropdown logic */
  
  .nav-menu-group {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px; /* Reduced gap to ensure visibility of all 4 items */
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* CTA Override: Cursive + Gradient */
  .nav-cta {
    font-family: var(--font-cursive) !important;
    font-size: 1.15rem !important;
    background: linear-gradient(135deg, var(--rose), var(--rose-dark)) !important;
    letter-spacing: 0.03em !important;
    padding: 6px 24px !important;
  }

  /* Language Selector Styles - Minimalist & Far Right */
  .lang-selector {
    position: relative;
    z-index: 200;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 6px 10px;
    border-radius: var(--radius-xl);
    cursor: pointer;
    transition: var(--transition);
  }

  .lang-btn:hover, .lang-btn.is-active {
    color: var(--rose);
    border-color: var(--rose);
    background: rgba(255, 75, 145, 0.05);
  }

  .lang-btn .chevron {
    transition: transform 0.3s ease;
    opacity: 0.5;
  }
  .lang-btn.is-active .chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    width: 160px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px) scale(0.95);
    transition: var(--transition);
    pointer-events: none;
  }

  .lang-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .dropdown-inner {
    background: var(--bg-tint);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 8px;
    box-shadow: var(--shadow-lg);
  }

  .lang-dropdown a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    color: var(--text-muted);
    font-size: 0.85rem;
    border-radius: var(--radius-sm);
    transition: var(--transition);
    text-decoration: none;
  }

  .lang-dropdown a:hover {
    background: rgba(255, 75, 145, 0.1);
    color: var(--rose);
  }

  .lang-dropdown a.active {
    color: var(--rose);
    font-weight: 600;
    background: rgba(255, 75, 145, 0.05);
  }

  .flag { font-size: 1.1rem; }

  @media (max-width: 1024px) {
    .nav-menu-group { gap: 20px; }
    .nav-actions { gap: 12px; }
  }

  @media (max-width: 820px) {
    .nav-links { gap: 16px; }
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
  }
</style>
