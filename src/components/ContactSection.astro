---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../i18n/utils';
import flower22 from '../assets/flowers/22.png';
import flower20 from '../assets/flowers/20.png';
import flower17 from '../assets/flowers/17.png';
import flower12 from '../assets/flowers/12.png';
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="section section-contact" id="contact">
  <!-- Decorative blob for contact section -->
  <div class="contact-blob" aria-hidden="true"></div>
  
  <!-- Large floating flowers -->
  <div class="floating-flower-contact reveal" aria-hidden="true" style="top: -100px; right: -100px;">
    <img src={flower22.src} alt="" />
  </div>

  <div class="floating-flower-contact reveal" aria-hidden="true" style="bottom: -80px; left: -120px; width: 350px; opacity: 0.12;">
    <img src={flower20.src} alt="" style="animation-delay: -2s;" />
  </div>

  <div class="floating-flower-contact reveal" aria-hidden="true" style="top: 20%; left: -60px; width: 180px; opacity: 0.1;">
    <img src={flower17.src} alt="" style="animation-delay: -5s; animation-duration: 12s;" />
  </div>

  <div class="floating-flower-contact reveal" aria-hidden="true" style="bottom: 20%; right: -50px; width: 220px; opacity: 0.08;">
    <img src={flower12.src} alt="" style="animation-delay: -1s; animation-duration: 15s;" />
  </div>

  <div class="container container-narrow">
    <div class="section-label reveal">{t('contact.title')}</div>
    <h2 class="section-title reveal">
      {lang === 'es' ? 'Construyamos algo' : lang === 'pt' ? 'Vamos construir algo' : "Let's build something"}<br />
      <em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); font-style: normal;">
        {lang === 'es' ? 'que valga la pena.' : lang === 'pt' ? 'que valha a pena.' : 'worth shipping.'}
      </em>
    </h2>

    <div class="contact-card reveal">
      <p class="contact-sub">
        {lang === 'es' ? 'Abierta a nuevas oportunidades, proyectos freelance y colaboraciones.' : lang === 'pt' ? 'Aberta a novas oportunidades, projetos freelancers e colaborações.' : "Open to new opportunities, freelance projects, and collaborations."}
      </p>
      
      <div class="contact-actions">
        <a href="mailto:jillglypuffhn@gmail.com" class="contact-btn">
          <div class="btn-icon">
            <Icon name="lucide:mail" size={20} />
          </div>
          <div class="btn-text">
            <span>{lang === 'es' ? 'Envíame un correo' : lang === 'pt' ? 'Envie-me um e-mail' : 'Send me an email'}</span>
            <strong>jillglypuffhn@gmail.com</strong>
          </div>
        </a>
      </div>

      <div class="contact-footer">
        <p class="contact-location">
          <Icon name="lucide:map-pin" size={16} />
          Santa Ana, San José, Costa Rica · {lang === 'es' ? 'Abierta a remoto' : lang === 'pt' ? 'Aberta a remoto' : 'Open to remote'}
        </p>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <p>© 2026 Jill Hernandez · {lang === 'es' ? 'Construido con intención.' : lang === 'pt' ? 'Construído com intenção.' : 'Built with intention.'}</p>
    </div>
  </div>
</footer>

<style>
  .section-contact {
    padding: 120px 0 160px;
    background: var(--bg);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .contact-blob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 75, 145, 0.08) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .floating-flower-contact {
    position: absolute;
    width: 400px;
    height: 400px;
    opacity: 0.15;
    z-index: 0;
    pointer-events: none;
  }

  .floating-flower-contact img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: hue-rotate(-10deg) brightness(1.2);
    animation: float 10s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    50% { transform: translate(-20px, 30px) rotate(5deg); }
  }

  .contact-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 60px 40px;
    backdrop-filter: blur(20px);
    box-shadow: var(--shadow-lg);
    position: relative;
    z-index: 1;
    margin-top: 40px;
  }

  .contact-sub {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .contact-actions {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255, 75, 145, 0.05);
    border: 1px solid var(--border);
    padding: 20px 32px;
    border-radius: var(--radius-md);
    transition: var(--transition);
    text-align: left;
  }

  .contact-btn:hover {
    background: rgba(255, 75, 145, 0.1);
    border-color: var(--rose);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .btn-icon {
    width: 48px;
    height: 48px;
    background: var(--rose);
    color: white;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 16px rgba(255, 75, 145, 0.3);
  }

  .btn-text {
    display: flex;
    flex-direction: column;
  }

  .btn-text span {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .btn-text strong {
    font-size: 1.2rem;
    color: var(--text);
    font-family: var(--font-display);
  }

  .contact-location {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: var(--text-muted);
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .footer {
    padding: 40px 0;
    background: var(--bg);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer-content p {
    color: var(--text-muted);
    font-size: 0.9rem;
    opacity: 0.6;
  }

  @media (max-width: 600px) {
    .contact-card {
      padding: 40px 24px;
    }
    .contact-btn {
      padding: 16px 20px;
      gap: 12px;
    }
    .btn-text strong {
      font-size: 1rem;
    }
    .floating-flower-contact {
      width: 250px;
      height: 250px;
      top: -50px;
      right: -50px;
    }
  }
</style>
