---
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="section" id="about">
  <div class="container">
    <div class="section-label reveal">{t('about.label')}</div>
    <div class="about-grid">
      <div class="about-text reveal">
        <h2 class="section-title">{t('about.title')}<br /><em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); opacity: 0.9;">{t('about.subtitle')}</em></h2>
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
        <p>{t('about.p3')}</p>
        <p>{t('about.p4')}</p>
      </div>
      <div class="about-stats reveal">
        <div class="stat-card">
          <span class="stat-number" data-target="3">3</span>
          <span class="stat-label">{t('about.stat.lang')}</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" data-target="4" data-plus="true">4+</span>
          <span class="stat-label">{t('about.stat.years')}</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" data-target="10" data-plus="true">10+</span>
          <span class="stat-label">{t('about.stat.tech')}</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" data-target="1">1</span>
          <span class="stat-label">{t('about.stat.role')}</span>
        </div>
      </div>
    </div>
  </div>
</section>
