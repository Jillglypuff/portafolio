---
import { useTranslations } from '../i18n/utils';
import ProjectsFloral from './ProjectsFloral.vue';
import ProjectStack from './ProjectStack.vue';

const { lang } = Astro.props;
const t = useTranslations(lang);

// Dynamically load images for stacks
const allCapturas = import.meta.glob('../assets/proyectos/capturas/*.{png,jpg,jpeg,JPG,PNG}', { eager: true, import: 'default' });
const canvaGlob = import.meta.glob('../assets/proyectos/diseños canva/*.{png,jpg,jpeg,JPG,PNG}', { eager: true, import: 'default' });
const figma = Object.values(import.meta.glob('../assets/proyectos/figma/*.{png,jpg,jpeg,JPG,PNG}', { eager: true, import: 'default' })).map((img: any) => img.src);

// Split Canva by aspect ratio
const canvaSquare: string[] = [];
const canvaPortrait: string[] = [];
Object.entries(canvaGlob).forEach(([path, img]: [string, any]) => {
  const fileName = path.split('/').pop() || '';
  if (['5.png', '6.png', '7.png', '8.png', '12.png'].includes(fileName)) {
    canvaSquare.push(img.src);
  } else {
    canvaPortrait.push(img.src);
  }
});

// Precise mapping for capturas
const mobileCapturas: string[] = [];
const webCapturas: string[] = [];

Object.entries(allCapturas).forEach(([path, img]: [string, any]) => {
  const fileName = path.split('/').pop() || '';
  const lowercaseName = fileName.toLowerCase();
  
  // Skip ss1, ss2, ss3 as requested
  if (lowercaseName.startsWith('ss1') || lowercaseName.startsWith('ss2') || lowercaseName.startsWith('ss3')) {
    return;
  }

  const mobileFiles = ['1.jpeg', '2.jpeg', '3.jpeg'];
  
  if (mobileFiles.includes(fileName)) {
    mobileCapturas.push(img.src);
  } else {
    webCapturas.push(img.src);
  }
});
---

<section class="section" id="projects">
  <div class="container">
    <div class="section-label reveal">{t('nav.projects')}</div>
    <h2 class="section-title reveal">
      {t('projects.title')}<br />
      <em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); opacity: 0.9;">
        {t('projects.subtitle')}
      </em>
    </h2>

    <div class="projects-grid">
      <!-- Row 1: 3 Items (Mobile, Content, Marketing) -->
      <div class="reveal row-1-item" style="transition-delay: 0.1s">
        <ProjectStack 
          client:visible
          title={t('projects.cat3')} 
          images={mobileCapturas}
          aspectRatio="portrait"
        />
      </div>
      <div class="reveal row-1-item" style="transition-delay: 0.2s">
        <ProjectStack 
          client:visible
          title={t('projects.cat2')} 
          images={canvaSquare}
          aspectRatio="square"
        />
      </div>
      <div class="reveal row-1-item" style="transition-delay: 0.3s">
        <ProjectStack 
          client:visible
          title={t('projects.cat5')} 
          images={canvaPortrait}
          aspectRatio="portrait"
        />
      </div>

      <!-- Row 2: 2 Items (UI Design, Web Systems) -->
      <div class="reveal row-2-item" style="transition-delay: 0.4s">
        <ProjectStack 
          client:visible
          title={t('projects.cat1')} 
          images={figma}
        />
      </div>
      <div class="reveal row-2-item" style="transition-delay: 0.5s">
        <ProjectStack 
          client:visible
          title={t('projects.cat4')} 
          images={webCapturas}
        />
      </div>
    </div>
  </div>

  <ProjectsFloral client:visible />
</section>

<style>
  #projects {
    padding: var(--section-padding, 120px) 0;
    min-height: auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 80px 40px;
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
  }

  .row-1-item {
    grid-column: span 2;
  }

  .row-2-item {
    grid-column: span 3;
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }

  @media (max-width: 1200px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 60px 30px;
    }
    .row-1-item, .row-2-item {
      grid-column: span 1;
      max-width: 100%;
    }
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
