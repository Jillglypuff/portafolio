    font-size: 0.8rem;
    font-weight: 700;
    color: var(--rose);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
    z-index: 2;
  }

  .card-body {
    flex: 1;
    z-index: 2;
    display: flex;
    flex-direction: column;
  }

  .card-post-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 800;
  }

  .card-post-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 32px;
    flex: 1;
  }

  .card-btn {
    align-self: flex-start;
    padding: 12px 28px;
    font-size: 0.95rem;
    z-index: 2;
  }

  /* ── Col 2: Upcoming card ── */
  .upcoming-card {
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .upcoming-header {
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 1;
  }

  .upcoming-heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .upcoming-list,
  .entries-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 1;
  }

  .upcoming-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .upcoming-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rose);
    margin-top: 5px;
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--rose);
  }

  .upcoming-info {
    flex: 1;
  }

  .upcoming-item-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-top: 0;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .upcoming-item-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Col 3: Entries card ── */
  .entries-card {
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .entries-header {
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 1;
  }

  .entry-read-link {
    display: inline-block;
    margin-top: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--rose);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .entry-read-link:hover {
    opacity: 0.75;
  }

  /* ── Slider Styles ── */
  .slider-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .entries-slider {
    display: flex;
    width: 100%;
    position: relative;
    min-height: 220px;
  }

  .slider-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transform: translateX(30px);
    transition: opacity 0.4s ease, transform 0.4s ease, visibility 0.4s;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 1;
  }

  .slider-slide.active {
    opacity: 1;
    visibility: visible;
    transform: translateX(0);
    position: relative;
    z-index: 2;
  }

  .slider-controls {
    display: flex;
    gap: 8px;
  }

  .slider-btn {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 75, 145, 0.25);
    color: var(--text);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
    font-size: 0.9rem;
  }

  .slider-btn:hover {
    background: rgba(255, 75, 145, 0.1);
    border-color: rgba(255, 75, 145, 0.6);
    transform: scale(1.05);
  }

  .slider-btn:active {
    transform: scale(0.95);
  }

  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
    z-index: 2;
  }

  .slider-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .slider-dot.active {
    background: var(--rose);
    transform: scale(1.2);
    box-shadow: 0 0 8px var(--rose);
  }

  .entry-number {
    font-size: 2.2rem;
    font-family: var(--font-display);
    font-weight: 800;
    color: rgba(255, 75, 145, 0.2);
    line-height: 1;
    margin-bottom: 8px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .blog-grid {
