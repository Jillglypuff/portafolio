</style>

<script>
  function setupCarousel() {
    const track = document.getElementById('entriesCarousel');
    if (!track) return;

    const slides = track.querySelectorAll('.carousel-slide');
    const wrapper = track.parentElement;
    const prevBtn = document.querySelector('.carousel-prev');
    const nextBtn = document.querySelector('.carousel-next');

    if (slides.length === 0) return;

    const perPage = 2;
    const totalPages = Math.ceil(slides.length / perPage);
    let currentPage = 0;

    if (totalPages <= 1) {
      if (prevBtn) prevBtn.style.display = 'none';
      if (nextBtn) nextBtn.style.display = 'none';
      return;
    }

    function goToPage(page) {
      if (page < 0) page = totalPages - 1;
      if (page >= totalPages) page = 0;
      var offset = page * wrapper.offsetHeight;
      track.style.transform = 'translateY(-' + offset + 'px)';
      currentPage = page;
    }

    if (prevBtn) {
      const newPrev = prevBtn.cloneNode(true);
      prevBtn.parentNode.replaceChild(newPrev, prevBtn);
      newPrev.addEventListener('click', function () { goToPage(currentPage - 1); });
    }

    if (nextBtn) {
      const newNext = nextBtn.cloneNode(true);
      nextBtn.parentNode.replaceChild(newNext, nextBtn);
      newNext.addEventListener('click', function () { goToPage(currentPage + 1); });
    }
  }

  document.addEventListener('astro:page-load', setupCarousel);
  setupCarousel();
</script>
