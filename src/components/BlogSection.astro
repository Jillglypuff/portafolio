---
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="section section-tinted" id="blog">
  <div class="container">
    <div class="section-label reveal">{t('nav.blog')}</div>
    <div class="blog-placeholder reveal">
      <h2 class="section-title">
        {lang === 'es' ? 'Próximamente' : lang === 'pt' ? 'Em breve' : 'Coming soon'}
        <br />
        <em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); opacity: 0.9;">
          {lang === 'es' ? 'Escribiendo experiencias' : lang === 'pt' ? 'Escrevendo experiências' : 'Writing experiences'}
        </em>
      </h2>
      <p style="max-width: 600px; margin: 0 auto; color: var(--text-muted);">
        {lang === 'es' ? 'Aquí compartiré mis aprendizajes sobre desarrollo full-stack, IA y la vida en la industria tech.' : 
         lang === 'pt' ? 'Aqui compartilharei meus aprendizados sobre desenvolvimento full-stack, IA e a vida na indústria de tecnologia.' : 
         'Here I will share my learnings about full-stack development, AI, and life in the tech industry.'}
      </p>
    </div>
  </div>
</section>

<style>
  .blog-placeholder {
    text-align: center;
    padding: 80px 24px;
    background: rgba(255, 75, 145, 0.03);
    border: 1px dashed rgba(255, 75, 145, 0.2);
    border-radius: 24px;
  }

  @media (max-width: 600px) {
    .blog-placeholder {
      padding: 48px 20px;
    }
  }
</style>
