---
import { useTranslations } from '../i18n/utils';
const { lang } = Astro.props;
const t = useTranslations(lang);

const content = {
  en: {
    title: "Developer Diary",
    subtitle: "Notes from my journey",
    pinnedLabel: "★ Recommended Start",
    readMore: "Read →",
    upcomingTitle: "Upcoming Articles",
    drafts: [
      { title: "Building with RAG & MCP", desc: "How I integrate Large Language Models with local databases using Model Context Protocol." },
      { title: "Shipping with Expo React Native", desc: "Tips and tricks for shipping cross-platform mobile apps faster." }
    ],
    featuredPost: {
      title: "Dear Diary, This Is Where It Begins 🌸",
      desc: "An introduction to my personal dev diary. Why I created this space, my journey from tech support to development, and what you'll find here."
    }
  },
  es: {
    title: "Diario de Desarrollo",
    subtitle: "Notas de mi viaje",
    pinnedLabel: "★ Te recomiendo iniciar por aquí",
    readMore: "Leer →",
    upcomingTitle: "Próximos Artículos",
    drafts: [
      { title: "Construyendo con RAG y MCP", desc: "Cómo integro Modelos de Lenguaje con bases de datos usando Model Context Protocol." },
      { title: "El Arte de Expo React Native", desc: "Consejos y trucos para publicar aplicaciones móviles multiplataforma rápidamente." }
    ],
    featuredPost: {
      title: "Querido Diario: Aquí es donde comienza 🌸",
      desc: "Una introducción a mi diario personal de desarrollo. Por qué creé este espacio, mi transición de soporte técnico a desarrollo y qué encontrarás aquí."
    }
  },
  pt: {
    title: "Diário de Desenvolvimento",
    subtitle: "Notas da minha jornada",
    pinnedLabel: "★ Recomendo começar por aqui",
    readMore: "Ler →",
    upcomingTitle: "Próximos Artigos",
    drafts: [
      { title: "Construindo com RAG e MCP", desc: "Como integro Modelos de Linguagem com bancos de dados usando Model Context Protocol." },
      { title: "A Arte do Expo React Native", desc: "Dicas e truques para publicar aplicativos móveis multiplataforma rapidamente." }
    ],
    featuredPost: {
      title: "Querido Diário, é aqui que começa 🌸",
      desc: "Uma introdução ao meu diário pessoal de desenvolvimento. Por que criei este espaço, minha transição do suporte técnico para o desenvolvimento e o que você encontrará aqui."
    }
  }
};

const page = content[lang] || content.es;
---

<section class="section section-tinted" id="blog">
  <div class="container">
    <div class="section-label reveal">{t('nav.blog')}</div>
    
    <div class="blog-header reveal">
      <h2 class="section-title">
        {page.title}
        <br />
        <em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); opacity: 0.9;">
          {page.subtitle}
        </em>
      </h2>
    </div>

    <!-- Blog Grid Layout -->
    <div class="blog-grid">
      
      <!-- Pinned Featured Post Card -->
      <div class="blog-card featured-blog-card reveal">
        <div class="card-glow"></div>
        <div class="badge-recommended">{page.pinnedLabel}</div>
        <div class="card-content">
          <h3 class="card-post-title">{page.featuredPost.title}</h3>
          <p class="card-post-desc">{page.featuredPost.desc}</p>
          <a href={`/${lang}/blog/`} class="btn btn-primary btn-read-more">
            {page.readMore}
          </a>
        </div>
      </div>

      <!-- Upcoming/Draft Posts Side Panel -->
      <div class="upcoming-panel reveal">
        <h3 class="upcoming-heading">{page.upcomingTitle}</h3>
        <div class="upcoming-list">
          {page.drafts.map((draft) => (
            <div class="upcoming-item">
              <div class="upcoming-bullet"></div>
              <div class="upcoming-info">
                <h4 class="upcoming-item-title">{draft.title}</h4>
                <p class="upcoming-item-desc">{draft.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .blog-header {
    margin-bottom: 40px;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: stretch;
  }

  /* Pinned Card Style */
  .featured-blog-card {
    position: relative;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 75, 145, 0.25);
    border-radius: 24px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
    transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .featured-blog-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 75, 145, 0.5);
    box-shadow: 0 20px 45px rgba(255, 75, 145, 0.12);
  }

  .card-glow {
    position: absolute;
    top: -20%;
    right: -20%;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(255, 75, 145, 0.12) 0%, transparent 70%);
    filter: blur(30px);
    z-index: 1;
    pointer-events: none;
  }

  .badge-recommended {
    display: inline-block;
    align-self: flex-start;
    padding: 6px 14px;
    background: rgba(255, 75, 145, 0.15);
    border: 1px solid rgba(255, 75, 145, 0.3);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--rose);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
    z-index: 2;
  }

  .card-content {
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: space-between;
  }

  .card-post-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 800;
  }

  .card-post-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .btn-read-more {
    align-self: flex-start;
    padding: 12px 28px;
    font-size: 0.95rem;
  }

  /* Upcoming Side Panel */
  .upcoming-panel {
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .upcoming-heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text);
    margin-bottom: 24px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 12px;
  }

  .upcoming-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .upcoming-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .upcoming-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rose);
    margin-top: 8px;
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--rose);
  }

  .upcoming-item-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }

  .upcoming-item-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Responsive Grid */
  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  @media (max-width: 600px) {
    .featured-blog-card {
      padding: 30px 20px;
    }
    .upcoming-panel {
      padding: 24px 20px;
    }
  }
</style>
