const rawPage = content[lang] || content.es;

// Obtener fecha actual en formato YYYY-MM-DD
const today = new Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

// Filtrar borradores que ya alcanzaron su fecha de publicación
const publishedDrafts = rawPage.drafts
  .filter(d => d.publishDate && d.publishDate <= todayStr)
  .map(d => ({
    number: d.number || "07",
    shortTitle: d.shortTitle || d.title,
    title: d.title,
    desc: d.desc,
    href: d.href || "#"
  }));

const page = {
  ...rawPage,
  // Agregar borradores publicados al inicio de la lista de entradas publicadas, ordenadas de más reciente a más antigua
  entries: [...publishedDrafts, ...rawPage.entries].sort((a, b) => parseInt(b.number, 10) - parseInt(a.number, 10)),
  // Dejar en drafts únicamente aquellos que no tienen fecha o su fecha es futura
  drafts: rawPage.drafts.filter(d => !d.publishDate || d.publishDate > todayStr)
};
---

<section class="section section-tinted" id="blog">
  <div class="container">
    <div class="section-label reveal">{t('nav.blog')}</div>
    
    <div class="blog-header reveal">
      <h2 class="section-title">
        {page.title}
        <br />
        <em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); opacity: 0.9;">
          {page.subtitle}
        </em>
      </h2>
    </div>

    <!-- 3-column blog grid -->
    <div class="blog-grid">

      <!-- ── Col 1: Pinned post (fixed) ── -->
      <div class="blog-card pinned-card reveal">
        <div class="card-glow glow-rose"></div>
        <div class="badge-pinned">{page.pinnedLabel}</div>
        <div class="card-body">
          <h3 class="card-post-title">{page.featuredPost.title}</h3>
          <p class="card-post-desc">{page.featuredPost.desc}</p>
        </div>
        <a href={`/${lang}/blog/`} class="btn btn-primary card-btn">
          {page.readMore}
        </a>
      </div>

      <!-- ── Col 2: Upcoming Articles ── -->
      <div class="blog-card upcoming-card reveal">
        <div class="card-glow glow-subtle"></div>
        <div class="upcoming-header">
          <h3 class="upcoming-heading">{page.upcomingTitle}</h3>
        </div>
        <div class="upcoming-list">
          {page.drafts.map((draft) => (
            <div class="upcoming-item">
              <div class="upcoming-bullet"></div>
              <div class="upcoming-info">
                <h4 class="upcoming-item-title">{draft.title}</h4>
                <p class="upcoming-item-desc">{draft.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Col 3: Entry card (carousel of 3) ── -->
      <div class="blog-card entries-card reveal">
        <div class="card-glow glow-subtle"></div>
        
        <div class="entries-header">
          <h3 class="upcoming-heading">{page.browseLabel}</h3>
          <div class="carousel-controls">
            <button class="carousel-btn carousel-prev" aria-label="Previous entries">←</button>
            <button class="carousel-btn carousel-next" aria-label="Next entries">→</button>
          </div>
        </div>

        <div class="carousel-wrapper">
          <div class="carousel-track" id="entriesCarousel">
            {page.entries.map((entry, idx) => (
              <div class="carousel-slide" data-index={idx}>
                <div class="carousel-card">
                  <div class="entry-number">{entry.number}</div>
                  <h4 class="carousel-card-title">{entry.title}</h4>
                  <p class="carousel-card-desc">{entry.desc}</p>
                  <a href={`/${lang}/${entry.href}/`} class="entry-read-link">{page.readMore}</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>



<style>
  .blog-header {
    margin-bottom: 40px;
  }

  /* Override container padding for this section only */
  #blog .container {
    padding-left: 16px;
    padding-right: 16px;
    max-width: 1400px;
  }

  /* ── 3-col equal grid ── */
  .blog-grid {
    display: grid;
    grid-template-columns: 4fr 3fr 6fr;
    gap: 24px;
    align-items: start;
  }

  /* ── Shared card base ── */
  .blog-card {
    position: relative;
    border-radius: 24px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.3);
  }

  /* Glow variants */
  .card-glow {
    position: absolute;
    top: -30%;
    right: -20%;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
    z-index: 0;
  }

  .glow-rose   { background: radial-gradient(circle, rgba(255, 75, 145, 0.14) 0%, transparent 70%); }
  .glow-subtle { background: radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, transparent 70%); }
  .glow-gold   { background: radial-gradient(circle, rgba(255, 200, 100, 0.12) 0%, transparent 70%); }

  /* ── Col 1: Pinned card ── */
  .pinned-card {
    border: 1px solid rgba(255, 75, 145, 0.25);
    justify-content: space-between;
  }

  .pinned-card:hover {
    border-color: rgba(255, 75, 145, 0.5);
    box-shadow: 0 20px 48px rgba(255, 75, 145, 0.12);
  }

  .badge-pinned {
    display: inline-block;
    align-self: flex-start;
    padding: 6px 14px;
    background: rgba(255, 75, 145, 0.15);
    border: 1px solid rgba(255, 75, 145, 0.3);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--rose);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 24px;
    z-index: 2;
  }

  .card-body {
    flex: 1;
    z-index: 2;
    display: flex;
    flex-direction: column;
  }

  .card-post-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 800;
  }

  .card-post-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 32px;
    flex: 1;
  }

  .card-btn {
    align-self: flex-start;
    padding: 12px 28px;
    font-size: 0.95rem;
    z-index: 2;
  }

  /* ── Col 2: Upcoming card ── */
  .upcoming-card {
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .upcoming-header {
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 1;
  }

  .upcoming-heading {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .upcoming-list,
  .entries-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 1;
  }

  .upcoming-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .upcoming-bullet {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rose);
    margin-top: 5px;
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--rose);
  }

  .upcoming-info {
    flex: 1;
  }

  .upcoming-item-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-top: 0;
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .upcoming-item-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Col 3: Entries card (carousel) ── */
  .entries-card {
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .entries-header {
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 1;
  }

  .entry-read-link {
    display: inline-block;
    margin-top: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--rose);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .entry-read-link:hover {
    opacity: 0.75;
  }

  /* ── Carousel Styles ── */
  .carousel-wrapper {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
    flex: none;
    display: block;
  }

  .carousel-track {
    display: block;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    width: 100%;
  }

  .carousel-slide {
    height: 200px;
    padding: 10px 0;
    display: flex;
  }

  .carousel-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
