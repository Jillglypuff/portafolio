const rawPage = content[lang] || content.es;

// Obtener fecha actual en formato YYYY-MM-DD
const today = new Date();
const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

// Filtrar borradores que ya alcanzaron su fecha de publicación
const publishedDrafts = rawPage.drafts
  .filter(d => d.publishDate && d.publishDate <= todayStr)
  .map(d => ({
    number: d.number || "07",
    shortTitle: d.shortTitle || d.title,
    title: d.title,
    desc: d.desc,
    href: d.href || "#"
  }));

const page = {
  ...rawPage,
  // Agregar borradores publicados al inicio de la lista de entradas publicadas
  entries: [...publishedDrafts, ...rawPage.entries],
  // Dejar en drafts únicamente aquellos que no tienen fecha o su fecha es futura
  drafts: rawPage.drafts.filter(d => !d.publishDate || d.publishDate > todayStr)
};
---

<section class="section section-tinted" id="blog">
  <div class="container">
    <div class="section-label reveal">{t('nav.blog')}</div>
    
    <div class="blog-header reveal">
      <h2 class="section-title">
        {page.title}
        <br />
        <em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); opacity: 0.9;">
          {page.subtitle}
        </em>
      </h2>
    </div>

    <!-- 3-column blog grid -->
    <div class="blog-grid">

      <!-- ── Col 1: Pinned post (fixed) ── -->
      <div class="blog-card pinned-card reveal">
        <div class="card-glow glow-rose"></div>
        <div class="badge-pinned">{page.pinnedLabel}</div>
        <div class="card-body">
          <h3 class="card-post-title">{page.featuredPost.title}</h3>
          <p class="card-post-desc">{page.featuredPost.desc}</p>
        </div>
        <a href={`/${lang}/blog/`} class="btn btn-primary card-btn">
          {page.readMore}
        </a>
      </div>

      <!-- ── Col 2: Upcoming Articles ── -->
      <div class="blog-card upcoming-card reveal">
        <div class="card-glow glow-subtle"></div>
        <div class="upcoming-header">
          <h3 class="upcoming-heading">{page.upcomingTitle}</h3>
        </div>
        <div class="upcoming-list">
          {page.drafts.map((draft) => (
            <div class="upcoming-item">
              <div class="upcoming-bullet"></div>
              <div class="upcoming-info">
                <h4 class="upcoming-item-title">{draft.title}</h4>
                <p class="upcoming-item-desc">{draft.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Col 3: Entry card (horizontal slider) ── -->
      <div class="blog-card entries-card reveal">
        <div class="card-glow glow-subtle"></div>
        
        <div class="entries-header">
          <h3 class="upcoming-heading">{page.browseLabel}</h3>
          <div class="slider-controls">
            <button class="slider-btn prev-btn" aria-label="Previous entry">←</button>
            <button class="slider-btn next-btn" aria-label="Next entry">→</button>
          </div>
        </div>

        <div class="slider-wrapper">
          <div class="entries-slider" id="entriesSlider">
            {page.entries.map((entry, idx) => (
              <div class={`slider-slide ${idx === 0 ? 'active' : ''}`} data-index={idx}>
                <div class="upcoming-info">
                  <div class="entry-number">{entry.number}</div>
                  <h4 class="upcoming-item-title">{entry.title}</h4>
                  <p class="upcoming-item-desc">{entry.desc}</p>
                  <a href={`/${lang}/${entry.href}/`} class="entry-read-link">{page.readMore}</a>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Dot indicators -->
        <div class="slider-dots">
          {page.entries.map((_, idx) => (
            <span class={`slider-dot ${idx === 0 ? 'active' : ''}`} data-index={idx}></span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>



<style>
  .blog-header {
    margin-bottom: 40px;
  }

  /* Override container padding for this section only */
  #blog .container {
    padding-left: 16px;
    padding-right: 16px;
    max-width: 1400px;
  }

  /* ── 3-col equal grid ── */
  .blog-grid {
    display: grid;
    grid-template-columns: 5fr 4fr 5fr;
    gap: 24px;
    align-items: start;
  }

  /* ── Shared card base ── */
  .blog-card {
    position: relative;
    border-radius: 24px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.3);
  }

  /* Glow variants */
  .card-glow {
    position: absolute;
    top: -30%;
    right: -20%;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    filter: blur(40px);
    pointer-events: none;
    z-index: 0;
  }

  .glow-rose   { background: radial-gradient(circle, rgba(255, 75, 145, 0.14) 0%, transparent 70%); }
  .glow-subtle { background: radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, transparent 70%); }
  .glow-gold   { background: radial-gradient(circle, rgba(255, 200, 100, 0.12) 0%, transparent 70%); }

  /* ── Col 1: Pinned card ── */
  .pinned-card {
    border: 1px solid rgba(255, 75, 145, 0.25);
    justify-content: space-between;
  }

  .pinned-card:hover {
    border-color: rgba(255, 75, 145, 0.5);
    box-shadow: 0 20px 48px rgba(255, 75, 145, 0.12);
  }

  .badge-pinned {
    display: inline-block;
