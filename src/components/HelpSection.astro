---
import { helpCards } from '../data/projects.js';
import { Icon } from 'astro-icon/components';
---
<section class="section section-tinted" id="help">
  <div class="container">
    <div class="section-label reveal">How I can help</div>
    <h2 class="section-title reveal">The problems I solve</h2>
    <div class="help-grid">
      {helpCards.map((card) => (
        <div class="help-card reveal">
          <div class="help-icon">
            <Icon name={card.icon} size={26} />
          </div>
          <h4>{card.title}</h4>
          <p>{card.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
