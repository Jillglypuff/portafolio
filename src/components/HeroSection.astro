---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '../i18n/utils';
import FloralBanner from './FloralBanner.vue';

const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="hero" id="hero">
  <FloralBanner client:load />
  <div class="hero-inner">
    <p class="hero-eyebrow" id="hero-eyebrow">{t('hero.eyebrow')}</p>
    <div style="overflow: hidden;">
      <h1 class="hero-name" id="hero-name">
        <span class="hero-name-line">Jill</span>
        <span class="hero-name-line accent" style="font-family: var(--font-cursive); font-size: 1.2em; font-weight: 400; margin-top: -10px;">Hernandez</span>
      </h1>
    </div>
    <div style="overflow: hidden;">
      <p class="hero-tagline" id="hero-tagline">{t('hero.tagline')}</p>
    </div>

    <div class="hero-actions" id="hero-actions">
      <a href={`/${lang}/#experience`} class="btn btn-primary">{t('hero.cta.work')}</a>
      <a href="mailto:jillhn1234@gmail.com" class="btn btn-ghost">{t('hero.cta.hello')}</a>
    </div>
  </div>



<style>
  .hero-flower-top {
    position: absolute;
    top: -60px;
    left: -40px;
    width: 200px;
    height: 200px;
    color: var(--rose);
    opacity: 0.1;
    z-index: -1;
    transform: rotate(-15deg);
  }
  .hero-flower-bottom {
    position: absolute;
    bottom: -80px;
    right: -40px;
    width: 300px;
    height: 300px;
    color: var(--rose);
    opacity: 0.08;
    z-index: -1;
    transform: rotate(20deg);
  }
</style>
</section>
