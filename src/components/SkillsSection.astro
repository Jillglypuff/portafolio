---
import Icon from './Icon.astro';
---
<section class="section" id="skills">
  <div class="container">
    <div class="section-label reveal">Skills</div>
    <h2 class="section-title reveal">What I build with</h2>
    <div class="skills-grid">
      <div class="skill-group reveal">
        <div class="skill-group-icon"><Icon name="palette" size={24} /></div>
        <h4 class="skill-group-title">Frontend</h4>
        <div class="skill-tags">
          <span class="skill-tag">Vue.js</span>
          <span class="skill-tag">React</span>
          <span class="skill-tag">JavaScript</span>
          <span class="skill-tag">HTML</span>
          <span class="skill-tag">CSS</span>
          <span class="skill-tag">Tailwind CSS</span>
        </div>
      </div>
      <div class="skill-group reveal">
        <div class="skill-group-icon"><Icon name="server" size={24} /></div>
        <h4 class="skill-group-title">Backend</h4>
        <div class="skill-tags">
          <span class="skill-tag">PHP</span>
          <span class="skill-tag">Node.js</span>
          <span class="skill-tag">Python</span>
          <span class="skill-tag">Java</span>
          <span class="skill-tag">Laravel</span>
          <span class="skill-tag">CodeIgniter</span>
        </div>
      </div>
      <div class="skill-group reveal">
        <div class="skill-group-icon"><Icon name="database" size={24} /></div>
        <h4 class="skill-group-title">Data & Databases</h4>
        <div class="skill-tags">
          <span class="skill-tag">MySQL</span>
          <span class="skill-tag">MongoDB</span>
          <span class="skill-tag">ERP</span>
        </div>
      </div>
      <div class="skill-group reveal">
        <div class="skill-group-icon"><Icon name="wrench" size={24} /></div>
        <h4 class="skill-group-title">Tools & Platforms</h4>
        <div class="skill-tags">
          <span class="skill-tag">Git</span>
          <span class="skill-tag">GitHub</span>
          <span class="skill-tag">WordPress</span>
          <span class="skill-tag">Salesforce</span>
          <span class="skill-tag">VS Code</span>
          <span class="skill-tag">Cursor</span>
        </div>
      </div>
      <div class="skill-group reveal">
        <div class="skill-group-icon"><Icon name="globe" size={24} /></div>
        <h4 class="skill-group-title">Languages</h4>
        <div class="skill-tags">
          <span class="skill-tag skill-tag-lang">English</span>
          <span class="skill-tag skill-tag-lang">Spanish</span>
          <span class="skill-tag skill-tag-lang">Portuguese</span>
        </div>
      </div>
      <div class="skill-group reveal">
        <div class="skill-group-icon"><Icon name="cpu" size={24} /></div>
        <h4 class="skill-group-title">AI & Emerging</h4>
        <div class="skill-tags">
          <span class="skill-tag">LLM Evaluation</span>
          <span class="skill-tag">Prompt Engineering</span>
          <span class="skill-tag">Android Studio</span>
        </div>
      </div>
    </div>
  </div>
</section>
