---
import { useTranslations } from '../i18n/utils';
import TechFloat from './TechFloat.vue';
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section class="section section-tech-hero" id="skills">
  <div class="container">
    <div class="section-label reveal">{t('nav.tech')}</div>
    <h2 class="section-title reveal">{t('nav.tech')}<br /><em style="font-family: var(--font-cursive); font-size: 1.25em; color: var(--rose); font-style: normal; opacity: 0.9;">Powered by code</em></h2>
  </div>

  <div class="tech-interaction-wrapper">
    <TechFloat client:load />
  </div>
</section>

<style>
  .section-tech-hero {
    padding-bottom: 0;
    overflow: hidden;
  }
  .tech-interaction-wrapper {
    position: relative;
    width: 100%;
    margin-top: -40px;
    z-index: 1;
  }
  
  @media (max-width: 768px) {
    .tech-interaction-wrapper {
      margin-top: 0;
    }
  }
</style>

