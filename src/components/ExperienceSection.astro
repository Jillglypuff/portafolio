---
import { Icon } from 'astro-icon/components';
import { featuredData, timelineData } from '../data/projects.js';
import { useTranslations } from '../i18n/utils';

const { lang } = Astro.props;
const t = useTranslations(lang);
const featured = featuredData[lang];
const timeline = timelineData[lang];
---
<section class="section section-tinted" id="experience">
  <div class="container">
    <div class="section-label reveal">{t('experience.title')}</div>
    <h2 class="section-title reveal">{t('experience.title')}<br /><em style="font-family: var(--font-cursive); font-size: 1.1em; color: var(--rose); opacity: 0.9;">Professional journey</em></h2>

    <div class="featured-card reveal">
      <div class="featured-header">
        <div>
          <div class="featured-tag">
            <Icon name="lucide:star" size={14} /> {featured.role} · {featured.period}
          </div>
          <h3 class="featured-title">{featured.role}</h3>
          <p class="featured-company">{featured.company} — {featured.location}</p>
        </div>
        <span class="status-badge status-active">In production</span>
      </div>

      <div class="featured-body">
        <!-- Problem -->
        <div class="featured-problem">
          <strong>The challenge:</strong> {featured.problem}
        </div>

        <!-- Metrics -->
        <div class="metrics-row">
          {featured.metrics.map((m) => (
            <div class="metric-chip">
              <span class="metric-value">{m.value}</span>
              <span class="metric-label">{m.label}</span>
              <span class="metric-note">{m.note}</span>
            </div>
          ))}
        </div>

        <!-- Flow -->
        <div class="flow-block">
          <div class="flow-label">How it works</div>
          <ol class="flow-steps">
            {featured.flow.map((step) => (
              <li class="flow-step">{step}</li>
            ))}
          </ol>
        </div>

        <!-- Bullets -->
        <ul class="featured-bullets">
          {featured.bullets.map((b) => (
            <li set:html={b} />
          ))}
        </ul>

        <!-- Stack -->
        <div class="featured-stack">
          {featured.stack.map((tech) => (
            <span class="tech-pill">{tech}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- ── Timeline ── -->
    <div class="timeline">
      <div class="timeline-line-track" aria-hidden="true">
        <div class="timeline-line-fill" id="timeline-line-fill"></div>
      </div>
      {timeline.map((item) => (
        <div class="timeline-item reveal">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="timeline-period">{item.period}</div>
            <h4 class="timeline-role">{item.role}</h4>
            <p class="timeline-org">{item.org}{item.location ? ` — ${item.location}` : ''}</p>
            <p class="timeline-desc">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
