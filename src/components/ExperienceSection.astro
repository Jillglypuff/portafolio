<section class="section section-tinted" id="experience">
  <div class="container">
    <div class="section-label reveal">Experience</div>
    <h2 class="section-title reveal">Where I've shipped<br /><em>real things</em></h2>

    <div class="featured-card reveal">
      <div class="featured-header">
        <div>
          <div class="featured-tag">⭐ Current role</div>
          <h3 class="featured-title">Junior Full-Stack Developer</h3>
          <p class="featured-company">Kapix — Santa Ana, Costa Rica</p>
        </div>
        <span class="status-badge status-active">In production</span>
      </div>
      <div class="featured-body">
        <div class="featured-problem">
          <strong>The challenge:</strong> Build and maintain multilingual web platforms — in English,
          Spanish, and Portuguese — that are fast, accessible, and consistent across browsers and devices.
        </div>
        <ul class="featured-bullets">
          <li>Designed dynamic front-end components using <strong>Vue.js</strong> and <strong>JavaScript</strong></li>
          <li>Built modular back-end services in <strong>PHP</strong> with responsive design principles</li>
          <li>Contributed to code reviews and proposed architectural improvements alongside senior devs</li>
          <li>Managed trilingual content (EN/ES/PT) optimized for accessibility and UX</li>
          <li>Used <strong>Git + GitHub</strong> for source control in distributed team workflows</li>
        </ul>
        <div class="featured-stack">
          <span class="tech-pill">Vue.js</span>
          <span class="tech-pill">JavaScript</span>
          <span class="tech-pill">PHP</span>
          <span class="tech-pill">Git</span>
          <span class="tech-pill">Agile</span>
        </div>
      </div>
    </div>

    <div class="timeline">
      <div class="timeline-line-track" aria-hidden="true">
        <div class="timeline-line-fill" id="timeline-line-fill"></div>
      </div>
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-period">Nov 2024 – Jan 2025</div>
          <h4 class="timeline-role">AI Trainer — Coder (Freelance)</h4>
          <p class="timeline-org">Outlier</p>
          <p class="timeline-desc">
            Evaluated and refined LLM-generated code in Python, Java, and JavaScript. Assessed prompts
            for accuracy, clarity, and technical correctness across multiple languages.
          </p>
        </div>
      </div>
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-period">Nov 2024 – Jan 2025</div>
          <h4 class="timeline-role">Technical Support Specialist</h4>
          <p class="timeline-org">ModSquad — Escazú, Costa Rica</p>
          <p class="timeline-desc">
            Provided bilingual (EN/ES) technical support for a global client base. Diagnosed issues
            and contributed to internal knowledge base documentation.
          </p>
        </div>
      </div>
      <div class="timeline-item reveal">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <div class="timeline-period">Feb 2020 – Mar 2024</div>
          <h4 class="timeline-role">AdOps Services Associate L3</h4>
          <p class="timeline-org">Amazon — Heredia, Costa Rica</p>
          <p class="timeline-desc">
            Operated and monitored advertising automation tools at scale. Identified and resolved system
            errors in real time. Supported internal stakeholders in launching ad campaigns aligned with KPIs.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
