---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { useTranslations } from '../../i18n/utils';
import Animations from '../../components/Animations.vue';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
    { params: { lang: 'pt' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const content = {
  en: {
    title: "Dear Diary, AI Is Already Generating Full Applications 🌸",
    date: "June 16, 2026",
    subtitle: "A developer diary by Jill",
    back: 'Back to Home',
    intro: "I still remember when generating a complete application sounded impossible.",
    introDesc: "A few prompts. A few clicks. And suddenly—",
    introExtra: [
      "there was frontend.",
      "Backend.",
      "Database.",
      "Routes.",
      "Components.",
      "Everything.",
      "My first reaction wasn't excitement.",
      "It was confusion.",
      "Wait.",
      "If this works… then what exactly are developers going to do?"
    ],
    firstAssumption: {
      heading: "My first wrong assumption",
      paragraphs: [
        "For a moment I thought development was becoming mostly writing code.",
        "And if AI could generate code… maybe the difficult part was disappearing.",
        "But the more I experimented with these tools… the more I realized something:",
        "generating code and building software are not the same thing."
      ]
    },
    discovery: {
      heading: "Discovery of the day",
      paragraphs: [
        "AI can generate applications.",
        "But applications still need decisions.",
        "Someone still needs to decide:",
        "🌸 What problem are we solving?<br>🌸 How should the systems connect?<br>🌸 What data should exist?<br>🌸 What should happen when something fails?<br>🌸 What should happen in production?<br>🌸 How should users move through the experience?",
        "Code appears faster.",
        "Questions don't."
      ]
    },
    invisibleWork: {
      heading: "The invisible part",
      paragraphs: [
        "Something I started noticing:",
        "The hardest moments weren't: writing components.",
        "They were:",
        "🌸 understanding requirements<br>🌸 deciding architecture<br>🌸 connecting systems<br>🌸 reviewing outputs<br>🌸 validating edge cases<br>🌸 debugging<br>🌸 maintaining",
        "And suddenly I understood something.",
        "The value isn't only in producing code.",
        "It's in understanding what should exist."
      ]
    },
    click: {
      heading: "When it finally clicked ✨",
      paragraphs: [
        "One day I generated something surprisingly complete.",
        "And for five minutes I thought: wow.",
        "Then I started reading.",
        "And noticed:",
        "the logic needed changes.",
        "the naming wasn't consistent.",
        "the flow didn't fully match the requirements.",
        "the architecture wasn't scalable.",
        "And that's when I realized:",
        "AI accelerated the first draft.",
        "Not the thinking."
      ]
    },
    personalNote: {
      heading: "Personal note 🌸",
      paragraphs: [
        "As someone who likes building things… this was unexpectedly comforting.",
        "Because maybe the goal was never to become faster at typing.",
        "Maybe the goal was becoming better at deciding.",
        "(And fortunately AI still cannot attend requirement meetings for me.)"
      ]
    },
    lesson: {
      heading: "The real lesson 💖",
      paragraphs: [
        "AI generating applications doesn't make development less valuable.",
        "If anything—it makes understanding systems more valuable.",
        "Because when generating becomes easier… making good decisions becomes the real skill."
      ]
    },
    remember: {
      heading: "Things I Want To Remember 🌷",
      items: [
        "Code generation is not architecture",
        "Faster doesn't always mean better",
        "Requirements still matter",
        "Systems are more than screens",
        "Understanding scales better than typing"
      ]
    },
    closing: "Next entry: GSAP and My Little Obsession With Animations",
    closingSign: "See you in the next entry ✨",
    signature: "— Jill"
  },
  es: {
    title: "Querido Diario, La IA Ya Está Generando Aplicaciones Completas 🌸",
    date: "16 de Junio, 2026",
    subtitle: "El diario de desarrollo de Jill",
    back: 'Volver al Inicio',
    intro: "Todavía recuerdo cuando generar una aplicación completa sonaba imposible.",
    introDesc: "Unos cuantos prompts. Unos cuantos clics. Y de repente—",
    introExtra: [
      "había frontend.",
      "Backend.",
      "Base de datos.",
      "Rutas.",
      "Componentes.",
      "Todo.",
      "Mi primera reacción no fue entusiasmo.",
      "Fue confusión.",
      "Espera.",
      "Si esto funciona… entonces, ¿qué es exactamente lo que van a hacer los desarrolladores?"
    ],
    firstAssumption: {
      heading: "Mi primer supuesto incorrecto",
      paragraphs: [
        "Por un momento pensé que el desarrollo se estaba convirtiendo principalmente en escribir código.",
        "Y si la IA podía generar código… tal vez la parte difícil estaba desapareciendo.",
        "But the more I experimented with these tools… the more I realized something:", // Translate to Spanish
        "generar código y construir software no son lo mismo."
      ]
    },
    discovery: {
      heading: "Descubrimiento del día",
      paragraphs: [
        "La IA puede generar aplicaciones.",
        "Pero las aplicaciones aún necesitan decisiones.",
        "Alguien todavía tiene que decidir:",
        "🌸 ¿Qué problema estamos resolviendo?<br>🌸 ¿Cómo deberían conectarse los sistemas?<br>🌸 ¿Qué datos deberían existir?<br>🌸 ¿Qué debería pasar cuando algo falla?<br>🌸 ¿Qué debería pasar en producción?<br>🌸 ¿Cómo deberían los usuarios moverse a través de la experiencia?",
        "El código aparece más rápido.",
        "Las preguntas no."
      ]
    },
    invisibleWork: {
      heading: "La parte invisible",
      paragraphs: [
        "Algo que empecé a notar:",
        "Los momentos más difíciles no eran: escribir componentes.",
        "Eran:",
        "🌸 entender los requisitos<br>🌸 decidir la arquitectura<br>🌸 conectar sistemas<br>🌸 revisar los resultados<br>🌸 validar casos extremos<br>🌸 depurar<br>🌸 mantener",
        "Y de repente entendí algo.",
        "El valor no está solo en producir código.",
        "Está en entender qué debería existir."
      ]
    },
    click: {
      heading: "Cuando finalmente hizo clic ✨",
      paragraphs: [
        "Un día generé algo sorprendentemente completo.",
        "Y durante cinco minutos pensé: wow.",
        "Luego empecé a leer.",
        "And noticed:", // Translate to Spanish
        "la lógica necesitaba cambios.",
        "los nombres no eran consistentes.",
        "el flujo no coincidía completamente con los requisitos.",
        "la arquitectura no era escalable.",
        "Y ahí fue cuando me di cuenta:",
        "La IA aceleró el primer borrador.",
        "Not the thinking." // Translate to Spanish
      ]
    },
    personalNote: {
      heading: "Nota personal 🌸",
      paragraphs: [
        "Como alguien a quien le gusta construir cosas… esto fue inesperadamente reconfortante.",
        "Porque tal vez el objetivo nunca fue escribir más rápido.",
        "Tal vez el objetivo era volverse mejor decidiendo.",
        "(Y afortunadamente la IA todavía no puede asistir a las reuniones de requisitos por mí)."
      ]
    },
    lesson: {
      heading: "La lección real 💖",
      paragraphs: [
        "Que la IA genere aplicaciones no hace que el desarrollo sea menos valioso.",
        "If anything—it makes understanding systems more valuable.", // Translate to Spanish
        "Porque cuando generar se vuelve más fácil… tomar buenas decisiones se convierte en la verdadera habilidad."
      ]
    },
    remember: {
      heading: "Cosas Que Quiero Recordar 🌷",
      items: [
        "La generación de código no es arquitectura",
        "Más rápido no siempre significa mejor",
        "Los requisitos siguen importando",
        "Los sistemas son más que pantallas",
        "Entender escala mejor que escribir"
      ]
    },
    closing: "Siguiente entrada: GSAP y Mi Pequeña Obsesión Con Las Animaciones",
    closingSign: "Nos vemos en la próxima entrada ✨",
    signature: "— Jill"
  },
  pt: {
    title: "Querido Diário, A IA Já Está Gerando Aplicativos Completos 🌸",
    date: "16 de Junho, 2026",
    subtitle: "Diário de desenvolvimento da Jill",
    back: 'Voltar ao Início',
    intro: "Ainda me lembro de quando gerar um aplicativo completo parecia impossível.",
    introDesc: "Alguns prompts. Alguns cliques. E de repente—",
    introExtra: [
      "havia frontend.",
      "Backend.",
      "Banco de dados.",
      "Rotas.",
      "Componentes.",
      "Tudo.",
      "Minha primeira reação não foi empolgação.",
      "Foi confusão.",
      "Espera.",
      "Se isso funciona… então o que exatamente os desenvolvedores vão fazer?"
    ],
    firstAssumption: {
      heading: "Minha primeira suposição errada",
      paragraphs: [
        "Por um momento, pensei que o desenvolvimento estava se tornando principalmente escrever código.",
        "E se a IA pudesse gerar código… talvez a parte difícil estivesse desaparecendo.",
        "Mas quanto mais eu experimentava com essas ferramentas… mais eu percebia algo:",
        "gerar código e construir software não são a mesma coisa."
      ]
    },
    discovery: {
      heading: "Descoberta do dia",
      paragraphs: [
        "A IA pode gerar aplicativos.",
        "Mas os aplicativos ainda precisam de decisões.",
        "Alguém ainda precisa decidir:",
        "🌸 Qual problema estamos resolvendo?<br>🌸 Como os sistemas devem se conectar?<br>🌸 Quais dados devem existir?<br>🌸 O que deve acontecer quando algo falha?<br>🌸 O que deve acontecer em produção?<br>🌸 Como os usuários devem navegar pela experiência?",
        "O código surge mais rápido.",
        "As perguntas não."
      ]
    },
    invisibleWork: {
      heading: "A parte invisível",
      paragraphs: [
        "Algo que comecei a notar:",
        "Os momentos mais difíceis não eram: escrever componentes.",
        "Eram:",
        "🌸 entender requisitos<br>🌸 decidir a arquitetura<br>🌸 conectar sistemas<br>🌸 revisar os resultados<br>🌸 validar casos extremos<br>🌸 depurar<br>🌸 manter",
        "E de repente eu entendi uma coisa.",
        "O valor não está apenas em produzir código.",
        "Está em entender o que deve existir."
      ]
    },
    click: {
      heading: "Quando finalmente fez sentido ✨",
      paragraphs: [
        "Um dia gerei algo surpreendentemente completo.",
        "E por cinco minutos pensei: uau.",
        "Depois comecei a ler.",
        "E notei:",
        "a lógica precisava de mudanças.",
        "os nomes não eram consistentes.",
        "o fluxo não correspondia totalmente aos requisitos.",
        "a arquitetura não era escalável.",
        "E foi aí que percebi:",
        "A IA acelerou o primeiro rascunho.",
        "Não o pensamento."
      ]
    },
    personalNote: {
      heading: "Nota pessoal 🌸",
      paragraphs: [
        "Como alguém que gosta de construir coisas… isso foi inesperadamente reconfortante.",
        "Porque talvez o objetivo nunca tenha sido digitar mais rápido.",
        "Talvez o objetivo fosse se tornar melhor em decidir.",
        "(E felizmente a IA ainda não pode participar de reuniões de requisitos por mim)."
      ]
    },
    lesson: {
      heading: "A lição real 💖",
      paragraphs: [
        "A IA gerando aplicativos não torna o desenvolvimento menos valioso.",
        "Pelo contrário—torna a compreensão dos sistemas mais valiosa.",
        "Porque quando gerar se torna mais fácil… tomar boas decisões se torna a verdadeira habilidade."
      ]
    },
    remember: {
      heading: "Coisas Que Quero Lembrar 🌷",
      items: [
        "Geração de código não é arquitetura",
        "Mais rápido nem sempre significa melhor",
        "Requisitos ainda importam",
        "Sistemas são mais do que telas",
        "Compreensão escala melhor do que digitação"
      ]
    },
    closing: "Próxima entrada: GSAP e Minha Pequena Obsessão por Animações",
    closingSign: "Até a próxima entrada ✨",
    signature: "— Jill"
  }
};

const page = content[lang] || content.es;
---

<Layout title={`${page.title} — Jill Hernandez`} lang={lang}>
  <Animations client:load />
  <Nav lang={lang} />
  
  <!-- Falling Petals Background Animation -->
  <div class="falling-petals-container" aria-hidden="true">
    <div class="petal p-1">🌸</div>
    <div class="petal p-2">🌸</div>
    <div class="petal p-3">🌸</div>
    <div class="petal p-4">🌸</div>
    <div class="petal p-5">🌸</div>
    <div class="petal p-6">🌸</div>
  </div>

  <main class="blog-view">
    <div class="blog-container container-narrow">
      
      <!-- Back navigation link -->
      <div class="back-nav reveal">
        <a href={`/${lang}/`} class="back-link">
          <span class="arrow">←</span> {page.back}
        </a>
      </div>

      <!-- Main Article Card -->
      <article class="blog-card reveal">

        <!-- Post Header: text only -->
        <header class="post-header">
          <div class="post-meta">
            <span class="post-category">🌷 {lang === 'en' ? 'Developer Diary' : lang === 'pt' ? 'Diário de Desenvolvimento' : 'Diario de Desarrollo'}</span>
            <span class="post-dot">•</span>
            <span class="post-date">{page.date}</span>
          </div>
          <h1 class="post-title">{page.title}</h1>
          <p class="post-subtitle">{page.subtitle}</p>
        </header>

        <!-- Post Content Body -->
        <div class="post-content">

          <!-- Intro -->
          <p class="lead-text">{page.intro}</p>
          <p class="lead-desc">{page.introDesc}</p>
          {page.introExtra.map((para) => (
            <p>{para}</p>
          ))}

          <hr class="post-divider" />

          <!-- My first assumption -->
          <div class="post-section">
            <h2 class="section-heading">{page.firstAssumption.heading}</h2>
            <div class="section-body">
              {page.firstAssumption.paragraphs.map((para) => (
                <p set:html={para}></p>
              ))}
            </div>
          </div>

          <hr class="post-divider" />

          <!-- Today's Discovery -->
          <div class="post-section">
            <h2 class="section-heading">{page.discovery.heading}</h2>
            <div class="section-body">
              {page.discovery.paragraphs.map((para) => (
                <p set:html={para}></p>
              ))}
            </div>
          </div>

          <hr class="post-divider" />

          <!-- The Invisible Work -->
          <div class="post-section">
            <h2 class="section-heading">{page.invisibleWork.heading}</h2>
            <div class="section-body">
              {page.invisibleWork.paragraphs.map((para) => (
                <p set:html={para}></p>
              ))}
            </div>
          </div>

          <hr class="post-divider" />

          <!-- What Made It Click -->
          <div class="post-section">
            <h2 class="section-heading">{page.click.heading}</h2>
            <div class="section-body">
              {page.click.paragraphs.map((para) => (
                <p set:html={para}></p>
              ))}
            </div>
          </div>

          <hr class="post-divider" />

          <!-- Personal note -->
          <div class="post-section">
            <h2 class="section-heading">{page.personalNote.heading}</h2>
            <div class="section-body">
              {page.personalNote.paragraphs.map((para) => (
                <p set:html={para}></p>
              ))}
            </div>
          </div>

          <hr class="post-divider" />

          <!-- The Real Lesson -->
          <div class="post-section">
            <h2 class="section-heading">{page.lesson.heading}</h2>
            <div class="section-body">
              {page.lesson.paragraphs.map((para) => (
                <p set:html={para}></p>
              ))}
            </div>
          </div>

          <hr class="post-divider" />

          <!-- Things I Want To Remember -->
          <div class="post-section remember-section">
            <h2 class="section-heading">{page.remember.heading}</h2>
            <ul class="remember-list">
              {page.remember.items.map((item) => (
                <li class="remember-item">
                  <span class="remember-dot">✦</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <hr class="post-divider" />

          <!-- Closing -->
          <div class="closing-block">
            <p class="closing-text">{page.closing}</p>
            <p class="closing-sign">{page.closingSign}</p>
            <p class="signature">{page.signature}</p>
          </div>

        </div>
      </article>

    </div>

    <!-- Decorative ambient flowers -->
    <div class="decorative-flower-1" aria-hidden="true">🌸</div>
    <div class="decorative-flower-2" aria-hidden="true">🌺</div>
  </main>
</Layout>

<style>
  /* Falling Petals Animation */
  .falling-petals-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    overflow: hidden;
  }

  .petal {
    position: absolute;
    top: -10%;
    font-size: 1.5rem;
    opacity: 0.6;
    filter: blur(0.5px);
    animation: fall 14s linear infinite;
    user-select: none;
  }

  .petal.p-1 { left: 10%; animation-delay: 0s; animation-duration: 16s; }
  .petal.p-2 { left: 28%; animation-delay: 3s; animation-duration: 13s; font-size: 1.2rem; }
  .petal.p-3 { left: 45%; animation-delay: 1.5s; animation-duration: 19s; }
  .petal.p-4 { left: 62%; animation-delay: 6s; animation-duration: 15s; font-size: 1rem; }
  .petal.p-5 { left: 78%; animation-delay: 4.5s; animation-duration: 17s; }
  .petal.p-6 { left: 92%; animation-delay: 8s; animation-duration: 14s; }

  @keyframes fall {
    0% {
      top: -10%;
      transform: translateX(0) rotate(0deg);
      opacity: 0;
    }
    10% {
      opacity: 0.7;
    }
    95% {
      opacity: 0.7;
    }
    100% {
      top: 110%;
      transform: translateX(100px) rotate(360deg);
      opacity: 0;
    }
  }

  .blog-view {
    min-height: 100vh;
    padding: 140px 20px 80px;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  .blog-container {
    max-width: 850px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
  }

  .back-nav {
    margin-bottom: 24px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .back-link:hover {
    color: var(--rose);
    transform: translateX(-4px);
  }

  /* Glassmorphic Blog Card */
  .blog-card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 75, 145, 0.15);
    border-radius: 28px;
    padding: 3.5rem 4rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .post-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 75, 145, 0.12);
    padding-bottom: 2.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: var(--rose);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
  }

  .post-dot {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .post-date {
    color: var(--text-muted);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 12px;
    font-weight: 850;
  }

  .post-subtitle {
    font-family: var(--font-cursive);
    font-size: 1.35rem;
    color: var(--rose);
    opacity: 0.95;
    margin: 0;
  }

  /* Post Content styling */
  .post-content {
    font-size: 1.125rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.85);
  }

  .post-content p {
    margin-bottom: 1.5rem;
  }

  .lead-text {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem !important;
  }

  .lead-desc {
    font-size: 1.18rem;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .post-divider {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(255, 75, 145, 0.25), transparent);
    margin: 3.5rem 0;
  }

  /* Section Styles */
  .post-section {
    margin-bottom: 0;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--text);
    margin-bottom: 1.25rem;
    font-weight: 700;
    position: relative;
    padding-bottom: 8px;
  }

  .section-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--rose);
    border-radius: 2px;
  }

  .section-body p {
    margin-bottom: 1.25rem;
  }

  /* Remember List */
  .remember-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .remember-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: rgba(255, 75, 145, 0.05);
    border: 1px solid rgba(255, 75, 145, 0.12);
    border-radius: 12px;
    padding: 14px 18px;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .remember-item:hover {
    background: rgba(255, 75, 145, 0.1);
    border-color: rgba(255, 75, 145, 0.25);
  }

  .remember-dot {
    color: var(--rose);
    font-size: 0.9rem;
    margin-top: 3px;
    flex-shrink: 0;
  }

  /* Closing Block */
  .closing-block {
    text-align: center;
    padding: 1rem 0;
  }

  .closing-text {
    font-size: 1.1rem;
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: 1rem !important;
  }

  .closing-sign {
    font-family: var(--font-cursive);
    font-size: 1.5rem;
    color: var(--rose);
    margin-bottom: 0.5rem !important;
  }

  .signature {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 !important;
  }

  /* Ambient Decor */
  .decorative-flower-1 {
    position: absolute;
    top: 15%;
    left: 8%;
    font-size: 5rem;
    opacity: 0.05;
    filter: blur(2px);
    transform: rotate(-15deg);
    pointer-events: none;
  }

  .decorative-flower-2 {
    position: absolute;
    bottom: 10%;
    right: 8%;
    font-size: 6rem;
    opacity: 0.07;
    filter: blur(3px);
    transform: rotate(25deg);
    pointer-events: none;
  }

  /* Responsiveness */
  @media (max-width: 768px) {
    .blog-view {
      padding: 100px 16px 60px;
    }
    .blog-card {
