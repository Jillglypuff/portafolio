          before: "npm install nombre-paquete",
          beforeLabel: "A veces esto:",
          after: "1 paquete\n↓\n32 dependencias\n↓\n145 subdependencias\n↓\nListo",
          afterLabel: "en realidad se convierte en:",
          note: "Lo que significa: no instalaste una sola cosa. Instalaste todo un árbol genealógico."
        },
        {
          title: "2. Las vulnerabilidades suelen descubrirse después",
          before: null,
          beforeLabel: null,
