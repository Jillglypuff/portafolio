        {
          title: "2. Vulnerabilidades costumam ser descobertas depois",
          before: null,
          beforeLabel: null,
          after: "Versão 2.4.0\n↓\nProblema de segurança descoberto\n↓\nCVE publicado\n↓\nAtualização recomendada",
